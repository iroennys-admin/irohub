<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.irohub" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/irohub_primary</item>
        <item name="colorPrimaryDark">@color/irohub_primary_dark</item>
        <item name="colorAccent">@color/irohub_accent</item>
        <item name="android:windowBackground">@color/irohub_bg</item>
        <item name="android:statusBarColor">@color/irohub_primary_dark</item>
        <item name="android:navigationBarColor">@color/irohub_bg</item>
    </style>

    <style name="Theme.irohub.NoDisplay" parent="Theme.irohub">
        <item name="android:windowBackground">@null</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>
</resources>
